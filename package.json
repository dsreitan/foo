{
  "name": "kobber-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run --filter demo dev",
    "build": "vp run --filter demo build",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "typecheck": "vp run --recursive typecheck"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite-plus": "^0.2.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": ">=10.9.0",
      "onFail": "warn"
    }
  }
}
